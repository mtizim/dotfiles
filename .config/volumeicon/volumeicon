[Alsa]
card=HDA Intel PCH
channel=Master
logarithmic_scale=false

[Notification]
show_notification=true
notification_type=0

[StatusIcon]
stepsize=5
onclick=xterm -e 'alsamixer'
theme=Blue Bar
use_panel_specific_icons=false
reverse_scroll_direction=false
lmb_slider=false
mmb_mute=false
use_horizontal_slider=true
show_sound_level=true
use_transparent_background=true

[Hotkeys]
up_enabled=true
down_enabled=true
mute_enabled=false
up=XF86AudioRaiseVolume
down=XF86AudioLowerVolume
mute=XF86AudioMute
